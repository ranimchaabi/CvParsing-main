@model ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<h1 class="text-danger">Erreur.</h1>
<h2 class="text-danger">Une erreur s'est produite lors du traitement de votre demande.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID de requête :</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Mode développement</h3>
<p>
    Le passage à l’environnement <strong>Development</strong> affichera des informations plus détaillées sur l’erreur.
</p>
<p>
    <strong>L’environnement Development ne doit pas être activé en production.</strong>
    Il peut exposer des informations sensibles. Pour le débogage local, définissez la variable
    <strong>ASPNETCORE_ENVIRONMENT</strong> sur <strong>Development</strong> puis redémarrez l’application.
</p>
