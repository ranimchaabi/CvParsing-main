@model CvParsing.ViewComponents.UserNavViewComponent.UserNavVm

@if (Model?.IsAuthenticated == true)
{
    var defaultAvatar = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'%3E%3Crect fill='%23f3f4f6' width='120' height='120'/%3E%3Cpath fill='%239ca3af' d='M60 62c12 0 22-10 22-22S72 18 60 18 38 28 38 40s10 22 22 22zm0 8c-15 0-28 7-28 16v6h56v-6c0-9-13-16-28-16z'/%3E%3C/svg%3E";
    var avatarSrc = string.IsNullOrWhiteSpace(Model.PhotoUrl) ? defaultAvatar : Model.PhotoUrl;
    <div class="user-nav" id="userNavRoot">
        <a class="user-nav__icon-btn" href="/Notifications" aria-label="Notifications">
            <i class='bx bx-bell' aria-hidden="true"></i>
        </a>

        <button type="button" class="user-nav__avatar-btn" id="userNavAvatarBtn" aria-haspopup="menu" aria-expanded="false">
            <img class="user-nav__avatar" src="@avatarSrc" alt="" />
        </button>

        <div class="user-nav__menu" id="userNavMenu" role="menu" aria-label="Menu utilisateur" hidden>
            <div class="user-nav__header">
                <div class="user-nav__header-avatar">
                    <img src="@avatarSrc" alt="" />
                </div>
                <div class="user-nav__header-text">
                    <div class="user-nav__name">@Model.UserName</div>
                    <div class="user-nav__role">@((Model.Designation ?? "Candidat"))</div>
                </div>
            </div>

            <a class="user-nav__item" role="menuitem" href="/Profile">
                <i class='bx bx-user' aria-hidden="true"></i>
                <span>Profil</span>
            </a>
            <a class="user-nav__item" role="menuitem" href="/Notifications">
                <i class='bx bx-bell' aria-hidden="true"></i>
                <span>Notifications</span>
            </a>
            <a class="user-nav__item" role="menuitem" href="/Profile#mes-candidatures">
                <i class='bx bx-file' aria-hidden="true"></i>
                <span>Mes candidatures</span>
            </a>

            <div class="user-nav__divider" role="separator"></div>

            <button type="button" class="user-nav__item user-nav__item--danger" id="logoutConfirmBtn" role="menuitem">
                <i class='bx bx-log-out' aria-hidden="true"></i>
                <span>Déconnexion</span>
            </button>
        </div>
    </div>
}

