@{
    ViewData["Title"] = "Connexion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-strip">
    <div class="container">
        <nav class="page-strip__nav" aria-label="Fil d'Ariane">
            <a href="/Home/Index">Accueil</a><span class="page-strip__sep">›</span><span class="page-strip__current">Connexion</span>
        </nav>
    </div>
</div>

<!-- User Area -->
<div class="user-area pt-100 pb-70">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="user-img">
                    <img src="~/images/user-img.png" alt="Images">
                </div>
            </div>

            <div class="col-lg-6">
                <div class="user-form">
                    <div class="contact-form">
                        <h2>Connexion</h2>

                        @if (!string.IsNullOrWhiteSpace(ViewBag.PasswordError as string))
                        {
                            <div class="alert alert-danger">@ViewBag.PasswordError</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(ViewBag.Error as string))
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <form asp-action="Login" asp-controller="Account" method="post" novalidate>
                            <input type="hidden" name="returnUrl" value="@(ViewBag.ReturnUrl ?? "")" />
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="form-group">
                                        <input type="text" name="username" class="form-control"
                                               required placeholder="Nom d'utilisateur ou Email">
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-group">
                                        <input type="password" name="password" class="form-control"
                                               required placeholder="Mot de passe">
                                        <small class="text-danger d-block mt-2" id="pwdInlineError" style="display:none;">
                                            Veuillez entrer le mot de passe
                                        </small>
                                    </div>
                                </div>

                                <div class="col-lg-12 form-condition">
                                    <div class="agree-label">
                                        <input type="checkbox" id="chb1">
                                        <label for="chb1">
                                            Se souvenir de moi
                                            <a class="forget" href="/Account/ForgotPassword">Mot de passe oublié ?</a>
                                        </label>
                                    </div>
                                </div>

                                <div class="col-lg-12">
                                    <button type="submit" class="default-btn btn-bg-two">
                                        Se connecter
                                    </button>
                                </div>

                                <div class="col-12">
                                    <p class="account-desc">
                                        Pas encore membre ?
                                        <a href="/Account/Register?returnUrl=@(ViewBag.ReturnUrl ?? "")">S'inscrire</a>
                                    </p>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- User Area End -->

@section Scripts {
    <script>
        (function () {
            var form = document.querySelector('form[asp-action="Login"], form[action*="Login"]');
            if (!form) return;
            var pwd = form.querySelector('input[name="password"]');
            var err = document.getElementById('pwdInlineError');
            if (!pwd || !err) return;

            form.addEventListener('submit', function (e) {
                var v = (pwd.value || '').trim();
                if (!v) {
                    e.preventDefault();
                    err.style.display = 'block';
                    pwd.focus();
                } else {
                    err.style.display = 'none';
                }
            });
        })();
    </script>
}
