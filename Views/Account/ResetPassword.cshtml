@{
    ViewData["Title"] = "Réinitialiser le mot de passe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="inner-banner">
    <div class="container">
        <div class="inner-title text-center">
            <h3>Reset Password</h3>
            <ul>
                <li><a href="/Home/Index">Home</a></li>
                <li>Reset Password</li>
            </ul>
        </div>
    </div>
</div>

<div class="user-area pt-100 pb-70">
    <div class="container">
        <div class="user-form">
            <div class="contact-form">
                <h2>Choose a new password</h2>

                <div id="resetError" class="alert alert-danger" style="display:none;"></div>
                <div id="resetSuccess" class="alert alert-success" style="display:none;"></div>

                <form id="resetForm" novalidate>
                    <input type="hidden" id="resetToken" name="token" value="" />

                    <div class="form-group">
                        <input type="password"
                               id="newPassword"
                               class="form-control"
                               placeholder="New password (min. 8 characters)"
                               required
                               minlength="8"
                               autocomplete="new-password" />
                    </div>

                    <div class="form-group">
                        <input type="password"
                               id="confirmPassword"
                               class="form-control"
                               placeholder="Confirm new password"
                               required
                               minlength="8"
                               autocomplete="new-password" />
                    </div>

                    <button type="submit" class="default-btn btn-bg-two">
                        Update password
                    </button>
                </form>

                <p class="account-desc mt-3">
                    <a href="/Account/Login">Back to login</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var params = new URLSearchParams(window.location.search);
            var token = params.get('token') || '';
            document.getElementById('resetToken').value = token;

            var form = document.getElementById('resetForm');
            var err = document.getElementById('resetError');
            var ok = document.getElementById('resetSuccess');

            function show(el, msg) {
                el.textContent = msg || '';
                el.style.display = msg ? 'block' : 'none';
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                show(err, '');
                show(ok, '');

                var t = document.getElementById('resetToken').value.trim();
                var p1 = document.getElementById('newPassword').value;
                var p2 = document.getElementById('confirmPassword').value;

                if (!t) {
                    show(err, 'Invalid or missing reset link. Please use the link from your email.');
                    return;
                }
                if (p1.length < 8 || p1 !== p2) {
                    show(err, 'Passwords must match and be at least 8 characters.');
                    return;
                }

                var res = await fetch('/auth/reset-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        token: t,
                        newPassword: p1,
                        confirmPassword: p2
                    })
                });

                var data = {};
                try { data = await res.json(); } catch (_) { }

                if (res.ok) {
                    show(ok, data.message || 'Your password has been reset.');
                    form.reset();
                } else {
                    show(err, data.message || 'Unable to reset password. Please request a new link.');
                }
            });
        })();
    </script>
}
