@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="inner-banner">
    <div class="container">
        <div class="inner-title text-center">
            <h3>Forgot Password</h3>
            <ul>
                <li><a href="/Home/Index">Home</a></li>
                <li>Forgot Password</li>
            </ul>
        </div>
    </div>
</div>

<div class="user-area pt-100 pb-70">
    <div class="container">
        <div class="user-form">
            <div class="contact-form">

                <h2>Reset your password</h2>

                <div id="fpError" class="alert alert-danger" style="display:none;"></div>
                <div id="fpSuccess" class="alert alert-success" style="display:none;"></div>

                <form id="forgotForm" novalidate>

                    <div class="form-group">
                        <input type="email"
                               id="fpEmail"
                               name="email"
                               class="form-control"
                               placeholder="Enter your email"
                               required />
                    </div>

                    <button type="submit" class="default-btn btn-bg-two">
                        Send Reset Link
                    </button>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var form = document.getElementById('forgotForm');
            var err = document.getElementById('fpError');
            var ok = document.getElementById('fpSuccess');

            function show(el, msg) {
                el.textContent = msg || '';
                el.style.display = msg ? 'block' : 'none';
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                show(err, '');
                show(ok, '');

                var email = (document.getElementById('fpEmail').value || '').trim();
                if (!email) {
                    show(err, 'Please enter your email.');
                    return;
                }

                var res = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({ email: email })
                });

                var data = {};
                try { data = await res.json(); } catch (_) { }

                if (res.ok) {
                    show(ok, data.message || 'If an account exists with this email, a reset link has been sent.');
                    form.reset();
                } else if (res.status === 429) {
                    show(err, data.message || 'Too many requests. Please try again later.');
                } else {
                    show(err, data.message || 'Something went wrong. Please try again.');
                }
            });
        })();
    </script>
}
