<!-- Blog Area -->
<div class="blog-area pt-100 pb-70">
    <div class="container">
        <div class="section-title text-center">
            <h2>Nos Dernières Offres d'Emploi</h2>
        </div>
        <div class="row pt-45">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="blog-card">
                        <div class="blog-img">
                            <a href="/Offre/Details/@item.id">
                                <img src="~/images/blog/blog-img1.jpg" alt="Blog Images">
                            </a>
                            <div class="blog-tag">
                                <h3>@item.date_creation?.Year</h3>
                            </div>
                        </div>
                        <div class="content">
                            <h3><a href="/Offre/Details/@item.id">@item.titre</a></h3>
                            <a href="/Offre/Details/@item.id" class="read-btn">Read More</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Blog Area End -->